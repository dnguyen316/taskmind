{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["eventId", "schemaVersion", "eventType", "occurredAt", "actorUserId", "scope", "entity", "payload", "context"],
  "properties": {
    "eventId": {"type": "string", "format": "uuid"},
    "schemaVersion": {"type": "integer", "const": 1},
    "eventType": {"type": "string", "minLength": 1},
    "occurredAt": {"type": "string", "format": "date-time"},
    "actorUserId": {"type": "string", "format": "uuid"},
    "scope": {
      "type": "object",
      "required": ["tenantId", "userId"],
      "properties": {"tenantId": {"type": "string"}, "userId": {"type": "string", "format": "uuid"}, "projectId": {"type": ["string", "null"], "format": "uuid"}}
    },
    "entity": {"type": "object", "required": ["type", "id"], "properties": {"type": {"type": "string"}, "id": {"type": "string", "format": "uuid"}}},
    "payload": {"type": "object"},
    "context": {"type": "object"}
  }
}
