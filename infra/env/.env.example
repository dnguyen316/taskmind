# TaskMind local development environment template.
# Copy to infra/env/.env with `make env-example` and override secrets locally.

# Core <-> Nova service-token contract.
# TASKMIND_NOVA_SERVICE_TOKEN is the canonical shared secret used by Core when
# calling Nova and by Nova when validating /internal/** requests.
TASKMIND_NOVA_SERVICE_TOKEN=development-only-nova-service-token
# Deprecated alias accepted by configuration for older deployments; keep equal
# to TASKMIND_NOVA_SERVICE_TOKEN until all environments are migrated.
TASKMIND_AI_SERVICE_TOKEN=development-only-nova-service-token

TASKMIND_CORE_SERVICE_TOKEN=local-core-token
TASKMIND_RELAY_SERVICE_TOKEN=local-relay-service-token

TASKMIND_CORE_BASE_URL=http://localhost:8080
TASKMIND_NOVA_BASE_URL=http://localhost:8082
TASKMIND_RELAY_BASE_URL=http://localhost:8081
